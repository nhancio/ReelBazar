# Local dev API URL. For production builds, set this in .env.production.
# Must include /api (client paths are /auth/..., /reels/...). Prod example: https://your-api.vercel.app/api
VITE_API_URL=http://localhost:4000/api
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=demo-reelbazaar
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
