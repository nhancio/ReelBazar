import React, { useRef, useEffect, useState } from 'react';
import type { Reel } from '@reelbazaar/config';

interface ReelCardProps {
  reel: Reel;
  isActive: boolean;
  onLike?: () => void;
  onSave?: () => void;
  onProductClick?: () => void;
  liked?: boolean;
  saved?: boolean;
}

export function ReelCard({ reel, isActive, onLike, onSave, onProductClick, liked, saved }: ReelCardProps) {
  const videoRef = useRef<HTMLVideoElement>(null);
  const [muted, setMuted] = useState(true);

  useEffect(() => {
    if (!videoRef.current) return;
    if (isActive) {
      videoRef.current.play().catch(() => {});
    } else {
      videoRef.current.pause();
      videoRef.current.currentTime = 0;
    }
  }, [isActive]);

  return (
    <div className="relative h-full w-full flex-shrink-0 snap-start overflow-hidden bg-black">
      <video
        ref={videoRef}
        src={reel.videoUrl}
        className="h-full w-full object-cover"
        loop
        muted={muted}
        playsInline
        onClick={() => setMuted(!muted)}
        poster={reel.thumbnailUrl || undefined}
      />

      <div className="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-black/20" />

      {/* Creator Info - Bottom Left */}
      <div className="absolute bottom-48 left-4 right-20 flex flex-col gap-3">
        <div className="flex items-center gap-2">
          <div className="flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-[#f1b3dd] via-[#a0bfff] to-[#6d8deb] text-sm font-semibold text-white border-2 border-white/20">
            {(reel.creator?.name || 'U').slice(0, 1).toUpperCase()}
          </div>
          <div className="flex flex-col drop-shadow-md">
            <span className="text-sm font-semibold text-white">
              {reel.creator?.name || 'Unknown Creator'}
            </span>
          </div>
          <button className="ml-2 rounded-full border border-white/50 px-3 py-1 text-xs font-semibold text-white backdrop-blur-sm transition hover:bg-white hover:text-black">
            Follow
          </button>
        </div>

        {reel.caption && (
          <p className="line-clamp-2 text-sm text-white/90 drop-shadow-md">
            {reel.caption}
          </p>
        )}

        {reel.brandTag && (
          <p className="text-xs text-white/80 drop-shadow-md">
            Sponsored by <span className="font-semibold">{reel.brandTag}</span>
          </p>
        )}
      </div>

      {/* Shop Button */}
      <div className="absolute bottom-32 left-4 right-20">
        <button
          onClick={onProductClick}
          className="flex w-full max-w-[280px] items-center justify-center gap-2 rounded-[16px] bg-white/20 px-4 py-3 text-sm font-semibold text-white shadow-lg backdrop-blur-xl border border-white/30 transition-transform hover:bg-white/30 active:scale-95"
        >
          <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
          View Product
        </button>
      </div>

      {/* Action Buttons - Bottom Right */}
      <div className="absolute bottom-32 right-4 flex flex-col items-center gap-6">
        <button onClick={onLike} className="group flex flex-col items-center gap-1 transition-transform active:scale-90">
          <div className="flex h-10 w-10 items-center justify-center rounded-full bg-black/20 backdrop-blur-md">
            <svg className={`h-6 w-6 transition-colors ${liked ? 'fill-red-500 text-red-500' : 'text-white group-hover:text-red-400'}`} viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
              <path strokeLinecap="round" strokeLinejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <span className="text-xs font-semibold text-white drop-shadow-md">{reel.likesCount}</span>
        </button>

        <button className="group flex flex-col items-center gap-1 transition-transform active:scale-90">
          <div className="flex h-10 w-10 items-center justify-center rounded-full bg-black/20 backdrop-blur-md">
            <svg className="h-6 w-6 text-white group-hover:text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}>
              <path strokeLinecap="round" strokeLinejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </div>
          <span className="text-xs font-semibold text-white drop-shadow-md">{Math.floor(reel.likesCount / 2)}</span>
        </button>

        <button onClick={onSave} className="group flex flex-col items-center gap-1 transition-transform active:scale-90">
          <div className="flex h-10 w-10 items-center justify-center rounded-full bg-black/20 backdrop-blur-md">
            <svg className={`h-6 w-6 transition-colors ${saved ? 'fill-yellow-400 text-yellow-400' : 'text-white group-hover:text-yellow-300'}`} viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
              <path strokeLinecap="round" strokeLinejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
            </svg>
          </div>
          <span className="text-xs font-semibold text-white drop-shadow-md">{reel.savesCount}</span>
        </button>

        <button className="group flex flex-col items-center gap-1 transition-transform active:scale-90">
          <div className="flex h-10 w-10 items-center justify-center rounded-full bg-black/20 backdrop-blur-md">
            <svg className="h-6 w-6 text-white group-hover:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
            </svg>
          </div>
        </button>
      </div>

      {muted && (
        <div className="absolute right-4 top-20 rounded-full bg-black/40 px-3 py-1.5 text-[11px] font-medium text-white backdrop-blur-md border border-white/20">
          Tap for sound
        </div>
      )}
    </div>
  );
}
